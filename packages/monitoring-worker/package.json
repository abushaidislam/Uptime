{
  "name": "@kit/monitoring-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/monitoring-service.js",
  "types": "./dist/monitoring-service.d.ts",
  "exports": {
    ".": "./dist/monitoring-service.js",
    "./monitoring": "./dist/monitoring-service.js",
    "./types": "./dist/types.d.ts"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules dist",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && node ./scripts/copy-email-assets.mjs",
    "start": "node dist/worker.js",
    "dev": "dotenv -e .env.development -- tsx src/worker.ts"
  },
  "prettier": "@kit/prettier-config",
  "dependencies": {
    "@kit/supabase": "workspace:*",
    "@supabase/supabase-js": "2.75.0",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "nodemailer": "^7.0.7"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/prettier-config": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "@types/node": "^24.7.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.11",
    "@types/nodemailer": "^7.0.1",
    "dotenv-cli": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
